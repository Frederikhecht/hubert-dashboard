<div class="min-h-screen flex items-center justify-center bg-neutral-50">
  <div class="w-full max-w-sm">
    <div class="mb-8 text-center">
      <h1 class="text-2xl font-semibold text-neutral-900">OpenClaw Dashboard</h1>
      <p class="mt-1 text-sm text-neutral-500">Sign in to continue</p>
    </div>

    <div class="bg-white rounded-xl border border-neutral-200 p-6 shadow-sm">
      <% if flash[:alert] %>
        <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: session_path, class: "flex flex-col gap-4" do |form| %>
        <div>
          <%= form.label :email_address, "Email", class: "block text-sm font-medium text-neutral-700 mb-1" %>
          <%= form.email_field :email_address,
              required: true, autofocus: true, autocomplete: "username",
              placeholder: "admin@example.com", value: params[:email_address],
              class: "w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900" %>
        </div>
        <div>
          <%= form.label :password, "Password", class: "block text-sm font-medium text-neutral-700 mb-1" %>
          <%= form.password_field :password,
              required: true, autocomplete: "current-password", maxlength: 72,
              class: "w-full rounded-md border border-neutral-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900" %>
        </div>
        <%= form.submit "Sign in",
            class: "w-full rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-800 focus:outline-none focus:ring-2 focus:ring-neutral-900 cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
